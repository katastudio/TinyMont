[node name="Marcos" parent="." instance=ExtResource("npc_src")]
position = Vector2(360, 56)
npc_name = "Marcos"
dialog_lines = ["El mejor cafe de
Monte Grande,
siempre calentito."]
piel = Color(0.780392, 0.560784, 0.4, 1)
pelo_color = Color(0.227451, 0.164706, 0.101961, 1)
gorra = "beanie"
gorra_color = Color(0.301961, 0.372549, 0.462745, 1)
vello_facial = "mustache"
camiseta = Color(0.435294, 0.305882, 0.215686, 1)
mision_id = "marcos_vasitos"
dialog_encargo = ["¡Bienvenido, pibe!
¿Recien bajas
del tren?", "Soy Marcos, vendo
cafe aca en la
estacion desde 2001.", "Justo se me acaban
los vasitos y no
puedo dejar el puesto.", "Haceme una gauchada:
anda a la Plaza Mitre,
ahi esta Sandra.", "Ella tiene vasitos
de sobra. Traeme
unos y arreglamos."]
dialog_recordatorio = ["¿Y los vasitos?
Sandra esta en la
Plaza Mitre, pibe.", "Sin vasitos no
puedo servir el
cafe, dale."]
dialog_entrega = ["¡Gracias, crack!
Justo a tiempo.", "Tomate un cafecito
de la casa, te lo
ganaste.", "Ya sos del barrio,
Monti. Bienvenido
a Monte Grande."]
requisito_item = "vasitos"
recompensa_item = "recuerdo"

