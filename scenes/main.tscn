marca = "stripes"
mision_id = "eldiez_pelota"
dialog_encargo = ["¡Eh, hola! Soy Leo,
de visita por
el barrio.", "Pateamos un rato
y la pelota se fue
a los arboles.", "¿Me la buscas?
No llego yo con
tanta gente."]
dialog_recordatorio = ["La pelota quedo
entre los arboles,
fijate.", "Sin pelota no hay
picadito, che."]
dialog_entrega = ["¡Esa! Gracias,
crack.", "Tomate un recuerdo.
Nos vemos, campeon."]
requisito_item = "pelota"
recompensa_item = "recuerdo"

