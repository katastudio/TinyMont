mision_id = "gille_trompeta"
dialog_encargo = ["¡Un caradura nuevo!
Soy Gille, toco la
trompeta.", "Despues del ensayo
me deje la trompeta
en la plaza.", "Buscala y traemela,
que sin ella no hay
zapada, che."]
dialog_recordatorio = ["¿La trompeta?
Anda a la plaza,
tiene que estar ahi.", "Sin trompeta no
sueno, pibe."]
dialog_entrega = ["¡Mi trompeta!
Gracias, grande.", "Tomate esto de
recuerdo. Ya sos de
la banda del barrio."]
requisito_item = "trompeta"
recompensa_item = "recuerdo"

[node name="ElDiez" parent="." instance=ExtResource("npc_src")]
position = Vector2(438, 135)
npc_name = "Leo"
dialog_lines = ["Aca cualquiera
juega bien. Es
el barrio."]
pelo_color = Color(0.352941, 0.227451, 0.101961, 1)
