mision_id = "rosa_gato"
dialog_encargo = ["¡Ay, nene!
Se me escapo
mi gato Mostaza.", "Es naranja con
manchas negras,
un amor.", "¿Me lo buscas?
No debe andar
lejos."]
dialog_recordatorio = ["¿Viste a Mostaza?
Naranja con
manchas negras.", "Se me escapa
siempre, el bandido."]
dialog_entrega = ["¡Mostaza! ¡Ay,
gracias, nene!", "Tomate un recuerdo,
sos un sol."]
